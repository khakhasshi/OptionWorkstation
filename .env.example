# Historical replay data. Market data is not distributed with this repository.
OPTION_WORKSTATION_DATA_ROOT=./data

# Local service binding. Keep 127.0.0.1 unless you intentionally add network controls.
OPTION_WORKSTATION_HOST=127.0.0.1
OPTION_WORKSTATION_PORT=7311

# Analytics configuration.
OPTION_WORKSTATION_RISK_FREE_RATE=0.043
OPTION_WORKSTATION_FRONTEND_DIST=./frontend/dist

# Append-only local research ledger.
OPTION_WORKSTATION_AUDIT_PATH=./.option-workstation/audit.jsonl

# Paper-order submission is disabled by default. Enabling this still requires
# a recognized paper account, a fresh strategy preview, and typed confirmation.
# OPTION_WORKSTATION_PAPER_ORDER_EXECUTION=1

RUST_LOG=option_workstation=info,tower_http=info
